{
  "manifest_version": 3,
  "name": "Scene Flow",
  "description": "Local-first timestamped prompt queue automation for Google Flow.",
  "version": "0.1.0",
  "action": {
    "default_title": "Scene Flow",
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://flow.google.com/*", "https://labs.google/fx/tools/flow*"],
      "js": ["content/flow-content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "activeTab", "downloads", "scripting", "debugger", "notifications", "alarms"],
  "host_permissions": ["https://flow.google.com/*", "https://labs.google/fx/tools/flow*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
